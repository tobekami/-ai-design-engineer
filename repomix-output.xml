    darkRing: z.string(),
});

export const LocksSchema = z.object({
    color: z.boolean(),
    harmony: z.boolean(),
    ideology: z.boolean(),
    fonts: z.boolean(),
    radius: z.boolean(),
});

export const ThemeConfigSchema = z.object({
    id: z.string(),
    primaryHex: z.string().regex(/^#[0-9A-Fa-f]{6}$/),
    harmonyType: HarmonyTypeSchema,
