<file path="src/lib/harmony/engine.ts">
import { hexToOklch, oklchToHex, shiftHue, shiftLightness, shiftChroma } from "./oklch";
import type { OklchColor } from "./oklch";
import type { HarmonyType } from "../schema/theme-config.schema";

export interface HarmonyPalette {
    primary: string;
    secondary: string;
    accent: string;
    complement: string;
    background: string;
    surface: string;
    muted: string;
    destructive: string;
}

function clampChroma(color: OklchColor): OklchColor {
    return { ...color, c: Math.min(color.c, 0.37) };
}

export function generateHarmony(
    primaryHex: string,
    harmonyType: HarmonyType
): HarmonyPalette {
    const primary = hexToOklch(primaryHex);

    let secondary: OklchColor;
    let accent: OklchColor;
    let complement: OklchColor;

    switch (harmonyType) {
        case "analogous":
            secondary = shiftHue(primary, 30);
            accent = shiftHue(primary, -30);
            complement = shiftHue(primary, 180);
            break;

        case "complementary":
            secondary = shiftHue(primary, 180);
            accent = shiftHue(primary, 90);
            complement = shiftHue(primary, 180);
            break;

        case "split-comp":
            secondary = shiftHue(primary, 150);
            accent = shiftHue(primary, 210);
            complement = shiftHue(primary, 180);
            break;

        case "triadic":
            secondary = shiftHue(primary, 120);
            accent = shiftHue(primary, 240);
            complement = shiftHue(primary, 180);
            break;

        case "tetradic":
            secondary = shiftHue(primary, 90);
            accent = shiftHue(primary, 180);
            complement = shiftHue(primary, 270);
            break;

        case "monochromatic":
            secondary = shiftLightness(shiftChroma(primary, -0.05), 0.15);
            accent = shiftLightness(shiftChroma(primary, 0.05), -0.1);
            complement = shiftLightness(primary, -0.2);
            break;

        default:
            secondary = shiftHue(primary, 30);
            accent = shiftHue(primary, -30);
            complement = shiftHue(primary, 180);
    }

    // Background: very low chroma, high lightness version of primary hue
    const background = clampChroma(
        shiftLightness(shiftChroma(primary, -primary.c + 0.02), 1 - primary.l - 0.05)
    );

    // Surface: slightly off-white with a hint of the primary hue
    const surface = clampChroma({
        ...primary,
        l: 0.97,
        c: 0.01,
    });

    // Muted: desaturated secondary
    const muted = clampChroma(
        shiftChroma(shiftLightness(secondary, 0.3 - secondary.l), -secondary.c + 0.03)
    );

    // Destructive: always a red-range hue
    const destructive: OklchColor = {
        l: 0.55,
        c: 0.22,
        h: 25,
    };

    return {
        primary: oklchToHex(clampChroma(primary)),
        secondary: oklchToHex(clampChroma(secondary)),
        accent: oklchToHex(clampChroma(accent)),
        complement: oklchToHex(clampChroma(complement)),
        background: oklchToHex(background),
        surface: oklchToHex(surface),
        muted: oklchToHex(muted),
        destructive: oklchToHex(destructive),
    };
}
</file>

<file path="src/lib/harmony/oklch.ts">
import { converter, formatHex, parse } from "culori";

const toOklch = converter("oklch");
const toRgb = converter("rgb");

export interface OklchColor {
    l: number; // 0–1
    c: number; // 0–0.4 approx
    h: number; // 0–360
}

export function hexToOklch(hex: string): OklchColor {
    const color = toOklch(hex);
    if (!color) throw new Error(`Invalid hex color: ${hex}`);
    return {
        l: color.l ?? 0,
        c: color.c ?? 0,
        h: color.h ?? 0,
    };
}

export function oklchToHex(oklch: OklchColor): string {
    const hex = formatHex({ mode: "oklch", ...oklch });
    return hex ?? "#000000";
}

export function oklchToCss(oklch: OklchColor): string {
    return `oklch(${(oklch.l * 100).toFixed(1)}% ${oklch.c.toFixed(4)} ${(oklch.h ?? 0).toFixed(1)})`;
}

export function hexToHsl(hex: string): string {
    const color = parse(hex);
    if (!color) return "0 0% 0%";
    const rgb = toRgb(color);
    if (!rgb) return "0 0% 0%";

    const r = (rgb.r ?? 0);
    const g = (rgb.g ?? 0);
    const b = (rgb.b ?? 0);

    const max = Math.max(r, g, b);
    const min = Math.min(r, g, b);
    let h = 0, s = 0;
    const l = (max + min) / 2;

    if (max !== min) {
        const d = max - min;
        s = l > 0.5 ? d / (2 - max - min) : d / (max + min);
        switch (max) {
            case r: h = ((g - b) / d + (g < b ? 6 : 0)) / 6; break;
            case g: h = ((b - r) / d + 2) / 6; break;
            case b: h = ((r - g) / d + 4) / 6; break;
        }
    }

    return `${Math.round(h * 360)} ${Math.round(s * 100)}% ${Math.round(l * 100)}%`;
}

export function shiftHue(oklch: OklchColor, degrees: number): OklchColor {
    return {
        ...oklch,
        h: ((oklch.h ?? 0) + degrees + 360) % 360,
    };
}

export function shiftLightness(oklch: OklchColor, amount: number): OklchColor {
    return {
        ...oklch,
        l: Math.max(0, Math.min(1, oklch.l + amount)),
    };
}

export function shiftChroma(oklch: OklchColor, amount: number): OklchColor {
    return {
        ...oklch,
        c: Math.max(0, oklch.c + amount),
    };
}

export function hexToOklchCss(hex: string): string {
    const oklch = hexToOklch(hex);
    return `oklch(${oklch.l.toFixed(4)} ${oklch.c.toFixed(4)} ${(oklch.h ?? 0).toFixed(2)})`;
}
</file>

<file path="src/lib/harmony/tokens.ts">
import { enforceMinContrast } from "./wcag";
import { hexToOklch, oklchToHex, shiftLightness, shiftChroma, hexToOklchCss } from "./oklch";
import type { HarmonyPalette } from "./engine";
import type { ShadcnTokenSet } from "../schema/theme-config.schema";

function deriveForeground(backgroundHex: string): string {
    const oklch = hexToOklch(backgroundHex);
    const fgOklch =
        oklch.l > 0.5
            ? { l: 0.15, c: oklch.c * 0.3, h: oklch.h }
            : { l: 0.97, c: oklch.c * 0.1, h: oklch.h };
    const fg = oklchToHex(fgOklch);
    return enforceMinContrast(fg, backgroundHex, 4.5);
}

function deriveDarkBackground(hex: string): string {
    const oklch = hexToOklch(hex);
    return oklchToHex({ l: 0.1, c: Math.min(oklch.c * 0.3, 0.02), h: oklch.h });
}

export function paletteToShadcnTokens(
    palette: HarmonyPalette,
    radiusPx: number = 8
): ShadcnTokenSet {
    // ── Light mode ──────────────────────────────────────────────
    const background = palette.background;
    const foreground = deriveForeground(background);
    const card = palette.surface;
    const cardForeground = deriveForeground(card);
    const popover = palette.surface;
    const popoverForeground = deriveForeground(popover);
    const primary = palette.primary;
    const primaryForeground = enforceMinContrast(deriveForeground(primary), primary, 4.5);

    const secondaryOklch = hexToOklch(palette.secondary);
    const secondaryLight = oklchToHex(shiftLightness(shiftChroma(secondaryOklch, -secondaryOklch.c + 0.04), 0.85));
    const secondary = secondaryLight;
    const secondaryForeground = deriveForeground(secondary);

    const mutedOklch = hexToOklch(palette.muted);
    const mutedLight = oklchToHex({ ...mutedOklch, l: 0.94, c: 0.02 });
    const muted = mutedLight;
    const mutedForeground = enforceMinContrast(
        oklchToHex({ ...mutedOklch, l: 0.45, c: 0.06 }), muted, 4.5
    );

    const accentOklch = hexToOklch(palette.accent);
    const accentLight = oklchToHex(shiftLightness(shiftChroma(accentOklch, -accentOklch.c + 0.04), 0.88));
    const accent = accentLight;
    const accentForeground = deriveForeground(accent);

    const destructive = palette.destructive;
    const destructiveForeground = enforceMinContrast("#ffffff", destructive, 4.5);

    const borderOklch = hexToOklch(background);
    const border = oklchToHex({ ...borderOklch, l: borderOklch.l - 0.08, c: 0.02 });
    const input = oklchToHex({ ...borderOklch, l: borderOklch.l - 0.05, c: 0.01 });
    const ring = palette.primary;

    // ── Dark mode ────────────────────────────────────────────────
    const darkBg = deriveDarkBackground(palette.primary);
    const darkBackground = darkBg;
    const darkForeground = enforceMinContrast(
        oklchToHex({ l: 0.95, c: 0.01, h: hexToOklch(palette.primary).h }), darkBg, 4.5
    );

    const darkCardOklch = hexToOklch(darkBg);
    const darkCard = oklchToHex({ ...darkCardOklch, l: darkCardOklch.l + 0.05 });
    const darkCardForeground = darkForeground;
    const darkPopover = darkCard;
    const darkPopoverForeground = darkForeground;

    const primaryOklch = hexToOklch(palette.primary);
    const darkPrimary = oklchToHex({
        ...primaryOklch,
        l: Math.min(primaryOklch.l + 0.1, 0.85),
        c: Math.min(primaryOklch.c + 0.02, 0.35),
    });
    const darkPrimaryForeground = enforceMinContrast(darkBackground, darkPrimary, 4.5);

    const darkSecondaryOklch = hexToOklch(darkBg);
    const darkSecondary = oklchToHex({ ...darkSecondaryOklch, l: 0.2, c: 0.02 });
    const darkSecondaryForeground = darkForeground;
    const darkMuted = oklchToHex({ ...darkSecondaryOklch, l: 0.18, c: 0.015 });
    const darkMutedForeground = enforceMinContrast(
        oklchToHex({ l: 0.65, c: 0.03, h: primaryOklch.h }), darkMuted, 4.5
    );

    const darkAccentOklch = hexToOklch(palette.accent);
    const darkAccent = oklchToHex({ ...darkAccentOklch, l: 0.22, c: Math.min(darkAccentOklch.c, 0.06) });
    const darkAccentForeground = darkForeground;
    const darkDestructive = oklchToHex({ l: 0.45, c: 0.22, h: 25 });
    const darkDestructiveForeground = enforceMinContrast("#ffffff", darkDestructive, 4.5);

    const darkBorderOklch = hexToOklch(darkBg);
    const darkBorder = oklchToHex({ ...darkBorderOklch, l: darkBorderOklch.l + 0.12, c: 0.02 });
    const darkInput = oklchToHex({ ...darkBorderOklch, l: darkBorderOklch.l + 0.08, c: 0.015 });
    const darkRing = darkPrimary;

    // Return oklch() CSS strings — matches base-nova variable format
    return {
        background: hexToOklchCss(background),
        foreground: hexToOklchCss(foreground),
        card: hexToOklchCss(card),
        cardForeground: hexToOklchCss(cardForeground),
        popover: hexToOklchCss(popover),
        popoverForeground: hexToOklchCss(popoverForeground),
        primary: hexToOklchCss(primary),
        primaryForeground: hexToOklchCss(primaryForeground),
        secondary: hexToOklchCss(secondary),
        secondaryForeground: hexToOklchCss(secondaryForeground),
        muted: hexToOklchCss(muted),
        mutedForeground: hexToOklchCss(mutedForeground),
        accent: hexToOklchCss(accent),
        accentForeground: hexToOklchCss(accentForeground),
        destructive: hexToOklchCss(destructive),
        destructiveForeground: hexToOklchCss(destructiveForeground),
        border: hexToOklchCss(border),
        input: hexToOklchCss(input),
        ring: hexToOklchCss(ring),
        radius: `${radiusPx}px`,
        darkBackground: hexToOklchCss(darkBackground),
        darkForeground: hexToOklchCss(darkForeground),
        darkCard: hexToOklchCss(darkCard),
        darkCardForeground: hexToOklchCss(darkCardForeground),
        darkPopover: hexToOklchCss(darkPopover),
        darkPopoverForeground: hexToOklchCss(darkPopoverForeground),
        darkPrimary: hexToOklchCss(darkPrimary),
        darkPrimaryForeground: hexToOklchCss(darkPrimaryForeground),
        darkSecondary: hexToOklchCss(darkSecondary),
        darkSecondaryForeground: hexToOklchCss(darkSecondaryForeground),
        darkMuted: hexToOklchCss(darkMuted),
        darkMutedForeground: hexToOklchCss(darkMutedForeground),
        darkAccent: hexToOklchCss(darkAccent),
        darkAccentForeground: hexToOklchCss(darkAccentForeground),
        darkDestructive: hexToOklchCss(darkDestructive),
        darkDestructiveForeground: hexToOklchCss(darkDestructiveForeground),
        darkBorder: hexToOklchCss(darkBorder),
        darkInput: hexToOklchCss(darkInput),
        darkRing: hexToOklchCss(darkRing),
    };
}
